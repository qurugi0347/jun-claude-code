{
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/skill-forced.sh\" ]; then \"$CLAUDE_PROJECT_DIR/.claude/hooks/skill-forced.sh\"; else \"$HOME/.claude/hooks/skill-forced.sh\"; fi"
          },
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/workflow-enforced.sh\" ]; then \"$CLAUDE_PROJECT_DIR/.claude/hooks/workflow-enforced.sh\"; else \"$HOME/.claude/hooks/workflow-enforced.sh\"; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_PROJECT_DIR/.claude/hooks/dangerous-command-blocker.sh\" ]; then \"$CLAUDE_PROJECT_DIR/.claude/hooks/dangerous-command-blocker.sh\"; else \"$HOME/.claude/hooks/dangerous-command-blocker.sh\"; fi"
          }
        ]
      }
    ]
  }
}
